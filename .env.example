# ──────────── Environment variables ────────────
# Copy this file to .env and fill in the values

# VM IPs
ORACLE_VM_PUBLIC_IP=<oracle-vm-public-ip>
HEADSCALE_VM_IP=<headscale-vm-ip>

# Mesh IPs (Tailscale/Headscale)
ORACLE_VM_MESH_IP=<oracle-vm-mesh-ip>
OPNSENSE_MESH_IP=<opnsense-mesh-ip>

# Domains
DUCKDNS_DOMAIN=<domain>.duckdns.org

# SSH
SSH_KEY_PATH=~/.ssh/<ssh-key>
SSH_USER=k3s
